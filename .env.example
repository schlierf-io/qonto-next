# Qonto API credentials — kept SERVER-SIDE only (never shipped to the browser).
# These are read by the Next.js Route Handlers under app/api/qonto/*.
QONTO_API_KEY=your_api_key_here
QONTO_ORG_SLUG=your_org_slug_here

# Optional override; defaults to the Qonto production third-party API.
QONTO_API_BASE_URL=https://thirdparty.qonto.com

# Gmail (read-only) — for sourcing missing invoices from email. SERVER-SIDE only.
# 1. Google Cloud: enable the Gmail API, create an OAuth client of type "Desktop".
#    Workspace domain (schlierf.eu) -> set the consent screen to "Internal".
# 2. Put the client id/secret below, then run once: node scripts/gmail-auth.mjs
#    and paste the printed GOOGLE_REFRESH_TOKEN.
# Verify with: GET /api/gmail/ping
# Scopes: gmail.readonly (search/read) + gmail.send (forward to Qonto).
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Your Qonto "receipt by email" inbox — forwarded invoices land here and Qonto
# auto-attaches them to the matching transaction. Find it in Qonto:
# Einstellungen -> Beleg per E-Mail importieren.
QONTO_RECEIPTS_INBOX=receipts-xxxx@inbox.qonto.com

# paperless-ngx (read-only) — alternative source for missing invoices. SERVER-SIDE
# only. PAPERLESS_URL is the instance base URL (NO trailing /api). Get a token in
# paperless-ngx: top-right user menu -> "My Profile" -> API Auth Token.
# Auth is a single header: Authorization: Token <token>.
# Verify with: GET /api/paperless/ping
PAPERLESS_URL=https://paperless.example.com
PAPERLESS_TOKEN=your_paperless_api_token

# n8n (local workflow automation, docker-compose) — dev only.
# Start:  pnpm n8n:up   ->  http://localhost:5680
# First visit creates the local owner account (n8n's built-in user management).
# N8N_ENCRYPTION_KEY must stay stable across restarts or saved credentials break;
# generate once with: openssl rand -hex 32
N8N_PORT=5680
N8N_TIMEZONE=Europe/Berlin
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
